{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kiwe.local/schemas/kiwe.bricks-bindings.v1.json",
  "title": "Kiwe Bricks Binding Plan",
  "description": "Read-only binding plan that maps an approved Kiwe website/page handoff to Bricks query loops, dynamic data, Kiwe launchers, and review items.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "siteGraphSchema",
    "target",
    "queries",
    "dynamicFields",
    "launchers",
    "menuContext",
    "assumptions",
    "requiresHumanReview"
  ],
  "properties": {
    "schema": {
      "const": "kiwe.bricks-bindings.v1"
    },
    "siteGraphSchema": {
      "const": "kiwe.site-graph.v1"
    },
    "target": {
      "type": "object",
      "additionalProperties": true,
      "required": ["builder", "mode", "applyAuthority"],
      "properties": {
        "builder": {
          "const": "bricks"
        },
        "mode": {
          "const": "binding-plan"
        },
        "applyAuthority": {
          "type": "string",
          "description": "Must indicate human review or a trusted Kiwe/Bricks adapter. The plan itself does not mutate WordPress."
        }
      }
    },
    "queries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/queryBinding"
      }
    },
    "dynamicFields": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dynamicField"
      }
    },
    "launchers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/launcher"
      }
    },
    "menuContext": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/menuContext"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": ["string", "object"]
      }
    },
    "requiresHumanReview": {
      "type": "array",
      "items": {
        "type": ["string", "object"]
      }
    }
  },
  "$defs": {
    "queryBinding": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "label", "selector", "bricks", "bindings"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "selector": {
          "type": "string",
          "minLength": 1
        },
        "bricks": {
          "type": "object",
          "additionalProperties": true,
          "required": ["objectType"],
          "properties": {
            "objectType": {
              "type": "string",
              "minLength": 1
            },
            "post_type": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "posts_per_page": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            },
            "tax_query": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^[a-z0-9_-]+::[0-9]+$"
              }
            },
            "tax_query_not": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^[a-z0-9_-]+::[0-9]+$"
              }
            }
          }
        },
        "bindings": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "object", "array", "number", "boolean", "null"]
          }
        }
      }
    },
    "dynamicField": {
      "type": "object",
      "additionalProperties": true,
      "required": ["selector", "field", "tag"],
      "properties": {
        "selector": {
          "type": "string",
          "minLength": 1
        },
        "field": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string",
          "pattern": "\\{[^{}]+\\}"
        }
      }
    },
    "launcher": {
      "type": "object",
      "additionalProperties": true,
      "required": ["selector", "attribute", "value"],
      "properties": {
        "selector": {
          "type": "string",
          "minLength": 1
        },
        "attribute": {
          "const": "data-dsa-open-module"
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "menuContext": {
      "type": "object",
      "additionalProperties": true,
      "required": ["label"],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "selector": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "source": {
          "type": "string"
        }
      }
    }
  }
}
