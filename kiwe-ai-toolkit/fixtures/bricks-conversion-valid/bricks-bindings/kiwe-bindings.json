{
  "schema": "kiwe.bricks-bindings.v1",
  "siteGraphSchema": "kiwe.site-graph.v1",
  "target": {
    "builder": "bricks",
    "mode": "binding-plan",
    "applyAuthority": "human-or-kiwe-adapter"
  },
  "queries": [
    {
      "id": "featured-products",
      "label": "Featured product rail",
      "selector": "[data-kiwe-binding='featured-products']",
      "bricks": {
        "objectType": "post",
        "post_type": ["product"],
        "posts_per_page": 4,
        "tax_query": ["product_cat::123"],
        "orderby": "menu_order",
        "order": "ASC"
      },
      "bindings": {
        "title": "{post_title}",
        "url": "{post_url}",
        "excerpt": "{post_excerpt}",
        "image": "{featured_image}"
      }
    }
  ],
  "dynamicFields": [
    {
      "selector": "#hero",
      "field": "siteTitle",
      "tag": "{site_title}"
    }
  ],
  "launchers": [
    {
      "selector": "[data-dsa-open-module='search']",
      "attribute": "data-dsa-open-module",
      "value": "search"
    }
  ],
  "menuContext": [
    {
      "label": "Featured products",
      "id": "featured-products",
      "source": "visible-section"
    }
  ],
  "assumptions": [],
  "requiresHumanReview": []
}
